# ==============================================================================
# Directus CMS - Bunny.net S3-Compatible Storage Configuration
# ==============================================================================
# This configuration snippet enables Directus CMS to natively read and write 
# recipe and product media assets directly to your Bunny.net Storage Zone 
# using Bunny's secure, high-performance S3-Compatible Gateway API.
#
# Place these variables inside your Directus `.env` file and restart your 
# container or service to apply them.
# ==============================================================================

# 1. Define the storage location name
STORAGE_LOCATIONS="bunny"

# 2. Configure the S3 driver for Bunny.net S3 Gateway
STORAGE_BUNNY_DRIVER="s3"

# 3. Credentials & Connection Details
# [Access Key ID] -> This is your Bunny.net Storage Zone Name (e.g. "supersauced")
STORAGE_BUNNY_KEY="supersauced"

# [Secret Access Key] -> This is your Storage Zone API Access Key (FTP Password)
# You can retrieve this under your Storage Zone -> "API Access" tab in the Bunny dashboard.
STORAGE_BUNNY_SECRET="your-bunny-storage-api-key-or-password"

# [Bucket Name] -> This must match your Storage Zone Name
STORAGE_BUNNY_BUCKET="supersauced"

# [S3 Endpoint] -> Use Bunny's global S3 endpoint or a region-specific endpoint:
# - Global/Germany (Europe): https://s3.bunnycdn.com
# - New York (USA): https://ny.s3.bunnycdn.com
# - Singapore (Asia): https://sg.s3.bunnycdn.com
STORAGE_BUNNY_ENDPOINT="https://s3.bunnycdn.com"

# [Region] -> Bunny's S3-compatible gateway requires a region value.
# Set this to "de", "ny", "sg", or "local" depending on your storage zone's main region.
STORAGE_BUNNY_REGION="de"

# 4. CDN Asset Serving (Highly Recommended)
# This instructs Directus to serve files using Bunny's blazing-fast Pull Zone CDN
# instead of proxying file reads back through Directus or hitting storage directly.
# Replace this with your actual Bunny Pull Zone URL (configured with Optimizer).
STORAGE_BUNNY_PUBLIC_ASSET_URL="https://supersauced.b-cdn.net"

# 5. Root Directory Path (Optional)
# If you wish to isolate Directus files to a specific directory within your storage zone.
STORAGE_BUNNY_ROOT="cms"
